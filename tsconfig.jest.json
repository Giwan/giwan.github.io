{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node16",
    "target": "ES2020",
    "jsx": "react",
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["jest", "node", "@testing-library/jest-dom"],
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "rootDir": "."
  }
}
