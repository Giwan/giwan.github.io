{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "jsx": "react",
        "esModuleInterop": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "./docs",
        "rootDir": ".",
        "paths": {
            "@/*": ["./src/*"]
