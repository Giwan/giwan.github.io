---
import HeaderLink from "../HeaderLink.astro";
import { CONFIG } from "../../config";
import HeaderNavMobile from "./HeaderNavMobile"; // jsx component

const links = CONFIG.navigation.header.filter(link => {
    if (link.href === "/tools" && !CONFIG.features.enableToolsPage) return false;
    if (link.href === "/search" && !CONFIG.features.enableSearch) return false;
    return true;
});
---

<nav id="navigation" aria-label="Main navigation" transition:name="navigation">
    <!-- Desktop Navigation -->
    <div
        class="hidden sm:flex justify-end items-center rounded-sm gap-1"
        transition:name="desktop-navigation"
    >
        {
            links.map(({ href, label }) => (
                <HeaderLink
                    href={href}
                    class="font-medium text-foreground hover:bg-accent focus:bg-accent focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:ring-offset-background transition-colors duration-200 rounded-sm text-base"
                    aria-label={`Navigate to ${label}`}
                    style={`view-transition-name: nav-link-${label.toLowerCase().replace(/\s+/g, '-')};`}
                >
                    {label}
                </HeaderLink>
            ))
        }
    </div>

    <!-- Mobile Navigation -->
    <div class="sm:hidden" transition:name="mobile-navigation">
        <HeaderNavMobile client:load />
    </div>
</nav>
