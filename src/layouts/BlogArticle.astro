---
import type { MarkdownLayoutProps } from 'astro';
import PageLayout from './PageLayout.astro';
import { SITE_CONFIG, ASSETS } from "../config";

type Props = MarkdownLayoutProps<{
  title: string;
  description: string;
  pubDate: string;
  updatedDate?: string;
  heroImage?: string;
  categories?: string[];
  tags?: string[];
  readTime?: number;
  createdDate?: string;
}>;

const { 
  frontmatter: { 
    title, 
    description, 
    pubDate, 
    createdDate,
    updatedDate,
    heroImage, 
    categories = [],
    tags = [],
    readTime
  } 
} = Astro.props;

const dateToUse = pubDate || createdDate || new Date().toISOString();

// Format the publish date in newspaper style
const formattedDate = new Date(dateToUse).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Format the updated date if it exists
const formattedUpdatedDate = updatedDate 
  ? new Date(updatedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : null;


const isoDate = new Date(dateToUse).toISOString();
const isoUpdatedDate = updatedDate ? new Date(updatedDate).toISOString() : isoDate;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(heroImage || '/images/social-card.png', Astro.site);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": Astro.site?.toString()
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": new URL("/blog", Astro.site).toString()
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": canonicalURL.toString()
    }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": {
    "@type": "ImageObject",
    "url": imageURL.toString(),
    "width": 1200,
    "height": 630
  },
  "datePublished": isoDate,
  "dateModified": isoUpdatedDate,
  "inLanguage": SITE_CONFIG.lang || "en-US",
  ...(readTime && { "timeRequired": `PT${readTime}M` }),
  ...(tags.length > 0 && { "keywords": tags.join(", ") }),
  ...(categories.length > 0 && { "articleSection": categories.join(", ") }),
  "author": {
    "@type": "Person",
    "name": SITE_CONFIG.author,
    "url": SITE_CONFIG.siteUrl,
    "sameAs": Object.entries(SITE_CONFIG.social || {}).map(([key, value]) => {
        if (key === 'twitter') return `https://twitter.com/${value}`;
        if (key === 'github') return `https://github.com/${value}`;
        if (key === 'linkedin') return `https://linkedin.com/in/${value}`;
        return value;
    }).filter(v => v.startsWith('http'))
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE_CONFIG.title,
    "logo": {
      "@type": "ImageObject",
      "url": new URL(ASSETS.favicon, Astro.site).toString(),
      "width": 60,
      "height": 60
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.toString()
  }
};
---

<PageLayout content={{ 
    title, 
    description,
    image: heroImage,
    article: true,
    publishedTime: isoDate,
    modifiedTime: isoUpdatedDate,
    author: SITE_CONFIG.author,
    section: categories[0],
    tags: tags,
    keywords: tags
}}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article 
    class="max-w-5xl mx-auto my-16 px-4 md:px-0"
    transition:name={`article-${Astro.url.pathname.replace(/\//g, '-')}`}
  >
    <!-- Article Header -->
    <header class="mb-12 pb-10 border-b border-border text-center">
      <!-- Categories -->
      {categories.length > 0 && (
        <div class="mb-6 flex justify-center gap-2">
          {categories.map((category: string) => (
            <a href={`/category/${category.toLowerCase()}`} class="text-xs font-bold uppercase tracking-widest text-muted-foreground hover:text-primary transition-colors border border-border px-2 py-1">
              {category}
            </a>
          ))}
        </div>
      )}
      
      <!-- Title -->
      <h1 class="text-5xl md:text-7xl font-heading font-extrabold text-primary mb-6 leading-tight max-w-4xl mx-auto">
        {title}
      </h1>

      <p class="text-xl md:text-2xl text-muted-foreground font-serif italic mb-8 max-w-2xl mx-auto leading-relaxed">
        {description}
      </p>
      
      <!-- Metadata Row -->
      <div class="flex flex-col items-center gap-2 text-sm font-bold uppercase tracking-tighter text-muted-foreground">
        <div class="flex items-center gap-2">
            <span>By {SITE_CONFIG.author}</span>
            <span class="w-1 h-1 bg-border rounded-full"></span>
            <time datetime={isoDate}>{formattedDate}</time>
        </div>
        {formattedUpdatedDate && (
          <span class="text-xs opacity-80">
            Last Updated: {formattedUpdatedDate}
          </span>
        )}
      </div>
    </header>
    
    <!-- Hero Image -->
    {heroImage && (
      <figure class="mb-12">
        <img 
          src={heroImage} 
          alt={`Image for ${title}`} 
          class="w-full h-auto border border-border grayscale hover:grayscale-0 transition-all duration-700"
        />
      </figure>
    )}
    
    <!-- Article Content -->
    <section class="prose prose-xl md:prose-2xl max-w-none dark:prose-invert font-serif leading-relaxed">
      <slot />
    </section>
    
    <!-- Article Footer -->
    <footer class="mt-12 pt-6 border-t border-border">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mb-6">
          <h3 class="text-sm uppercase tracking-wider text-muted-foreground mb-3">Related Topics</h3>
          <div class="flex flex-wrap">
            {tags.map((tag: string) => (
              <a href={`/tag/${tag.toLowerCase()}`} class="inline-block px-2 py-1 mr-2 mb-2 text-sm bg-muted text-muted-foreground rounded hover:bg-accent hover:text-accent-foreground transition-colors">
                #{tag}
              </a>
            ))}
          </div>
        </div>
      )}
      
      <!-- Share and Related Articles -->
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
        <div class="mb-4 sm:mb-0">
          <h3 class="text-sm uppercase tracking-wider text-muted-foreground mb-2">Connect</h3>
          <div class="flex space-x-3" role="list">
            {Object.entries(SITE_CONFIG.social || {}).map(([key, value]) => {
                let href = value;
                if (key === 'twitter') href = `https://twitter.com/${value}`;
                if (key === 'github') href = `https://github.com/${value}`;
                if (key === 'linkedin') href = `https://linkedin.com/in/${value}`;
                if (key === 'email') href = `mailto:${value}`;

                return (
                  <a href={href} class="text-muted-foreground hover:text-primary focus:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 rounded-sm p-1" rel="noopener noreferrer" target="_blank" role="listitem">
                    <span class="sr-only">{key}</span>
                    <span class="text-xs font-bold uppercase">{key}</span>
                  </a>
                )
            })}
          </div>
        </div>
        
        <a href="/" class="inline-flex items-center font-semibold link-hover">
          <span>More articles</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </footer>
  </article>
</PageLayout>

